# ============================================================
# REEVA Backend — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Perfil Spring: use "prod" em produção, "local" em desenvolvimento
SPRING_PROFILES_ACTIVE=local

# ── Banco de dados ──────────────────────────────────────────
# Local com Docker Compose: jdbc:postgresql://localhost:5432/reeva
# Nuvem (Railway, Supabase, RDS, etc.): cole a URL fornecida pela plataforma
DB_URL=jdbc:postgresql://localhost:5432/reeva
DB_USERNAME=reeva
DB_PASSWORD=reeva

# ── Segurança JWT ───────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=change-this-secret-in-production-must-be-256-bits
# Expiração em ms: 86400000 = 24h
JWT_EXPIRATION=86400000

# ── CORS (produção) ─────────────────────────────────────────
# URL do frontend em produção — obrigatório quando SPRING_PROFILES_ACTIVE=prod
# Exemplo: https://app.reeva.com.br
APP_CORS_ALLOWED_ORIGINS=

# ── OpenAI — OCR e análise de notas fiscais ─────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Armazenamento de arquivos ───────────────────────────────
# "local" (padrão): arquivos salvos em disco no diretório UPLOAD_DIR
# "s3": arquivos enviados ao Amazon S3 (configurar variáveis abaixo)
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# ── AWS S3 ──────────────────────────────────────────────────
AWS_S3_BUCKET=reeva-reembolsos
AWS_REGION=sa-east-1

# Opcional: apenas para serviços S3-compatíveis como LocalStack ou MinIO
AWS_S3_ENDPOINT=

# Opcional: URL pública base para os arquivos (ex: https://cdn.reeva.com.br)
AWS_S3_PUBLIC_BASE_URL=

# Credenciais AWS (deixe em branco se usar IAM Role em EC2/ECS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
