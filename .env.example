JWT_SECRET=change-this-secret-in-production-must-be-256-bits

# OpenAI - used for invoice OCR (Vision API)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Storage mode: use "s3" to send uploaded images to Amazon S3
STORAGE_PROVIDER=s3

# AWS S3 configuration
AWS_S3_BUCKET=reeva-reembolsos
AWS_REGION=sa-east-1

# Optional, only if using S3-compatible services like LocalStack/MinIO
AWS_S3_ENDPOINT=

# Optional, only if you want a direct public URL saved in the database
AWS_S3_PUBLIC_BASE_URL=

# AWS credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
